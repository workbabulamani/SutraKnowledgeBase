# ============================================================
# GRNTH VAULT — Environment Configuration
# ============================================================
# Copy this file to .env and update the values as needed.
# cp .env-sample .env
# ============================================================

# Secret key for signing JWT auth tokens.
# IMPORTANT: Change this to a strong, random string in production!
JWT_SECRET=md-viewer-super-secret-key-change-me-in-production

# Port the server listens on (3001 for local dev, 3000 in Docker)
PORT=3001

# Path to the SQLite database file
DB_PATH=./data/md_viewer.db

# Directory where uploaded images are stored
UPLOAD_DIR=./data/uploads/images

# Encryption key for server-side database backups.
# IMPORTANT: Change this to a strong, random string!
ENCRYPTION_KEY=grnth-backup-encryption-key-change-me

# Default admin account credentials (created on first run)
# IMPORTANT: Change the password in production!
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123

# Auto-logout after this many minutes of inactivity
SESSION_TIMEOUT=30

# Set to "true" to allow public user registration.
# When "false", only the admin can create new users via Settings → Users.
ALLOW_SIGNUP=false

# CORS allowed origins. Controls which domains can access the API.
#   *                              → Allow all origins (local/intranet use)
#   https://vault.example.com      → Single domain (e.g. Cloudflare tunnel)
#   https://a.com,http://b.com:3001 → Comma-separated multiple origins
# ─── Local / Intranet (allow everything) ───

# EXAMPLES
# ─── Single Cloudflare Tunnel domain ───
#ALLOWED_ORIGINS=https://vault.yourdomain.com

# ─── Cloudflare Tunnel + local network access ───
#ALLOWED_ORIGINS=https://vault.yourdomain.com,http://192.168.1.100:3000

# ─── Multiple domains (tunnel + custom domain + LAN) ───
#ALLOWED_ORIGINS=https://vault.yourdomain.com,https://notes.yourdomain.com,http://192.168.1.100:3000

# ─── Port-forwarded with a dynamic DNS ───
#ALLOWED_ORIGINS=https://myvault.duckdns.org:3000

ALLOWED_ORIGINS=*
